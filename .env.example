# Copy to .env and adjust. Used by docker-compose and local apps.

# --- Docker published ports ---
POSTGRES_PORT=5432
REDIS_PORT=6379
WEAVIATE_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Postgres ---
POSTGRES_USER=aimarketplace
POSTGRES_PASSWORD=aimarketplace
POSTGRES_DB=aimarketplace

# --- MinIO (S3-compatible local storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- App (API runs on host; compose provides backing services) ---
PORT=3001
DATABASE_URL=postgresql://aimarketplace:aimarketplace@localhost:5432/aimarketplace
REDIS_URL=redis://localhost:6379
WEAVIATE_URL=http://localhost:8080
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aimarketplace
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Frontend talks to API (Vite dev server)
VITE_API_URL=http://localhost:3001
