# Copy to .env and adjust. Used by docker-compose and local apps.

# --- Docker published ports ---
POSTGRES_PORT=5432
REDIS_PORT=6379
WEAVIATE_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Postgres ---
POSTGRES_USER=aimarketplace
POSTGRES_PASSWORD=aimarketplace
POSTGRES_DB=aimarketplace

# --- MinIO (S3-compatible local storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- App (API runs on host; compose provides backing services) ---
PORT=3001
# Required for auth JWTs (use a long random string in real deployments).
JWT_SECRET=change-me-to-a-long-random-secret
DATABASE_URL=postgresql://aimarketplace:aimarketplace@localhost:5432/aimarketplace
# After changing Prisma schema: run `npm run db:migrate -w apps/api` (dev) or `npm run db:deploy -w apps/api` (CI/prod).
REDIS_URL=redis://localhost:6379
WEAVIATE_URL=http://localhost:8080
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aimarketplace
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Frontend → API
# - Vite `server` / `preview` proxy target (see apps/web/vite.config.ts). Defaults to localhost:3001 if unset.
# - Browser: leave VITE_API_URL unset or empty to use same-origin `/api` (works with dev + preview proxy).
# - Set to a full origin (e.g. http://localhost:3001) when serving static `dist/` without Vite proxy.
# VITE_API_URL=
