# Copy to .env and adjust. Used by docker-compose and local apps.

# --- Docker published ports ---
POSTGRES_PORT=5432
REDIS_PORT=6379
WEAVIATE_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Postgres ---
POSTGRES_USER=aimarketplace
POSTGRES_PASSWORD=aimarketplace
POSTGRES_DB=aimarketplace

# --- MinIO (S3-compatible local storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- App (API runs on host; compose provides backing services) ---
PORT=3001
# Required for auth JWTs (use a long random string in real deployments).
JWT_SECRET=change-me-to-a-long-random-secret
DATABASE_URL=postgresql://aimarketplace:aimarketplace@localhost:5432/aimarketplace
# After changing Prisma schema: run `npm run db:migrate -w apps/api` (dev) or `npm run db:deploy -w apps/api` (CI/prod).
REDIS_URL=redis://localhost:6379
WEAVIATE_URL=http://localhost:8080
# Optional: HTTP timeout (ms) for Weaviate requests (default 45000).
# WEAVIATE_REQUEST_TIMEOUT_MS=45000
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aimarketplace
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Document embeddings (DeepInfra OpenAI-compatible API) ---
# Token: https://deepinfra.com/dash/api_keys
# Omit all embedding keys below to disable the document pipeline; other routes still start.
# Defaults: EMBEDDING_BASE_URL=https://api.deepinfra.com/v1/openai , EMBEDDING_MODEL=BAAI/bge-m3-multi
#
# DEEPINFRA_API_KEY="..."
# Optional overrides:
# EMBEDDING_BASE_URL="https://api.deepinfra.com/v1/openai"
# EMBEDDING_MODEL="BAAI/bge-m3-multi"
#
# Alias: DEEPINFRA_TOKEN (same as DEEPINFRA_API_KEY). Fallback: OPENAI_API_KEY + OPENAI_BASE_URL for other providers.

# --- RAG chat (LangGraph: plan → retrieve_documents → LLM) ---
# Requires a working document pipeline above. Chat can use the same or a different OpenAI-compatible host.
# CHAT_API_KEY="..."   (else OPENAI_API_KEY / DEEPINFRA_*)
# CHAT_BASE_URL="https://api.openai.com/v1"
# LLM_MODEL="gpt-4o-mini"
# CHAT_TEMPERATURE=0.2

# Frontend → API
# - Vite `server` / `preview` proxy target (see apps/web/vite.config.ts). Defaults to localhost:3001 if unset.
# - Browser: leave VITE_API_URL unset or empty to use same-origin `/api` (works with dev + preview proxy).
# - Set to a full origin (e.g. http://localhost:3001) when serving static `dist/` without Vite proxy.
# VITE_API_URL=

# --- LangSmith (optional; LLM traces for skill chat via LangChain ChatOpenAI) ---
# https://docs.smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY="your-langsmith-api-key"
# LANGSMITH_PROJECT="AiMarketPlace"